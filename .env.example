# TamaleBot Agent Configuration
# Copy to .env and fill in your values.

# --- LLM Provider (required) ---
TAMALEBOT_API_KEY=
TAMALEBOT_PROVIDER=anthropic          # anthropic, openai, moonshot, google, minimax
TAMALEBOT_MODEL=                      # Leave empty for provider default

# --- Agent Settings ---
TAMALEBOT_SYSTEM_PROMPT=              # Custom system prompt (optional)
TAMALEBOT_POLICY=default              # Security policy: default, strict, permissive
TAMALEBOT_MODE=repl                   # repl (interactive) or http (server)
TAMALEBOT_STORAGE_PATH=/tmp/workspace/.tamalebot-data

# --- Cost Optimization (optional) ---
TAMALEBOT_ROUTER_MODEL=               # e.g. claude-haiku-4-5-20251001 (enables smart routing)

# --- Integrations (set tokens to enable) ---
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
EMAIL_IMAP_HOST=
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
